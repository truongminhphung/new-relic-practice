aws_region            = "ap-southeast-1"
dockerhub_username    = "truongminhphungdocker"
image_tag             = "latest"
new_relic_app_name    = "etl-job"
log_retention_days    = 14
schedule_expression   = "cron(0 10 * * ? *)"

# new_relic_license_key is sensitive — do not put it here.
# Pass it via environment variable instead:
#   export TF_VAR_new_relic_license_key="YOUR_KEY"
